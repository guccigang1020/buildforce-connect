# Supabase (public — safe to expose in browser bundles)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-public-key
SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_PROJECT_ID=your-project-id

# Supabase service role (SECRET — server-side only, set in deployment secrets)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Lovable platform API key (SECRET — server-side only)
# LOVABLE_API_KEY=your-lovable-api-key
